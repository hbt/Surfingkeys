{
  "name": "Surfingkeys",
  "version": "1.17.12",
  "description": "Map your keys for web surfing, expand your browser with javascript and keyboard.",
  "main": "background.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "clean": "rm -rf dist/*",
    "build:doc": "documentation build src/content_scripts/common/api.js src/content_scripts/common/normal.js src/content_scripts/common/clipboard.js src/content_scripts/common/hints.js src/content_scripts/common/visual.js src/content_scripts/front.js src/user_scripts/index.js -f md -o docs/api.md",
    "build:doc-cmds": "bun scripts/generate-command-docs.js",
    "build:doc-chrome-api": "bash scripts/fetch-all-chrome-apis.sh",
    "build:dev": "node ./config/esbuild.config.js development",
    "build:prod": "node ./config/esbuild.config.js production",
    "build": "npm-run-all clean test build:doc build:doc-chrome-api build:prod",
    "watch": "node ./config/esbuild.config.js development --watch",
    "cov:html": "bun scripts/cov.ts",
    "cov:sequential": "bun scripts/cov-sequential.ts",
    "cov:parallel": "bun scripts/cov-parallel.ts",
    "server:start": "bun scripts/server.ts",
    "server:status": "bin/dbg server-status",
    "lint": "bun scripts/run-lint.js",
    "lint:js": "eslint --config config/eslint.config.js src tests debug scripts --ext .js,.ts",
    "lint:css": "stylelint --config config/stylelint.config.js 'src/**/*.css'",
    "config:lint": "node scripts/lint-config.js",
    "validate:mappings": "bun scripts/validate-mappings.ts",
    "validate:mappings:prefixes": "bun scripts/validate-mappings.ts --prefixes",
    "report:migration": "bun scripts/find-migrated-commands.js",
    "report:mappings:json": "bun scripts/mappings-json-report.ts",
    "report:audit": "bun scripts/mappings-json-report.ts | bun scripts/audit-report.ts",
    "test:playwright": "CONFIG_SERVER_PORT=9602 BUILD_SUFFIX=-test npm run build:dev && bunx playwright test",
    "test:playwright:parallel": "CONFIG_SERVER_PORT=9602 BUILD_SUFFIX=-test npm run build:dev && bun scripts/test-parallel.ts",
    "worktree:setup": "bun scripts/worktree-setup.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brookhong/Surfingkeys.git"
  },
  "author": "brook hong",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/brookhong/Surfingkeys/issues"
  },
  "homepage": "https://github.com/brookhong/Surfingkeys#readme",
  "devDependencies": {
    "@babel/parser": "^7.28.6",
    "@babel/traverse": "^7.28.6",
    "@babel/types": "^7.28.6",
    "@playwright/test": "^1.58.2",
    "@types/chrome": "^0.1.35",
    "@types/events": "^3.0.0",
    "@types/lodash": "^4.14.172",
    "@types/offscreencanvas": "^2019.6.4",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "documentation": "^14.0.3",
    "dotenv": "^17.2.3",
    "esbuild": "^0.27.2",
    "esbuild-plugin-copy": "^2.1.1",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "strict-event-emitter-types": "^2.0.0",
    "stylelint": "^17.0.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^4.5.4",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "@msgpack/msgpack": "^2.7.0",
    "@pixi/app": "^7.4.0",
    "@pixi/constants": "^7.4.0",
    "@pixi/core": "^7.4.0",
    "@pixi/display": "^7.4.0",
    "@pixi/extensions": "^7.4.0",
    "@pixi/graphics": "^7.4.0",
    "@pixi/math": "^7.4.0",
    "@pixi/runner": "^7.4.0",
    "@pixi/settings": "^7.4.0",
    "@pixi/sprite": "^7.4.0",
    "@pixi/ticker": "^7.4.0",
    "@pixi/unsafe-eval": "^7.4.0",
    "@pixi/utils": "^7.4.0",
    "ace-builds": "^1.4.12",
    "aws4fetch": "^1.0.20",
    "dompurify": "^3.2.4",
    "events": "^3.3.0",
    "js-base64": "^3.7.2",
    "lodash": "^4.17.21",
    "marked": "^4.0.10",
    "pdfjs-dist": "4.8.69"
  }
}
